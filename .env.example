# ---- Server ---------------------------------------------------------------
PORT=8000

# ---- Postgres + pgvector --------------------------------------------------
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# ---- Redis (BullMQ) -------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Gemini ---------------------------------------------------------------
# Google AI Studio key (free tier). Get one at https://aistudio.google.com/apikey
# If unset, the service falls back to a deterministic offline embedder + an
# extractive answer, so the whole stack and the eval still run with no key.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_LLM_MODEL=gemini-1.5-flash
# text-embedding-004 outputs 768-d vectors; must match the chunks.embedding column.
EMBEDDING_DIM=768

# ---- Chunking -------------------------------------------------------------
# Paragraph-aware chunking: pack paragraphs up to CHUNK_MAX_TOKENS with
# CHUNK_OVERLAP_TOKENS carried between consecutive chunks.
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# ---- Retrieval ------------------------------------------------------------
RETRIEVAL_TOP_N=20
RETRIEVAL_TOP_K=5
